# Copy to backend/_common/.env — shared by all microservices (pydantic-settings env_file).
# Server
DATABASE_URL=postgresql://user:password@localhost:5432/ai-carrier-mentor
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# Pinecone
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX_NAME=ai-hr-vacancies
PINECONE_NAMESPACE=vacancies

GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_CHAT_MODEL=llama-3.1-8b-instant