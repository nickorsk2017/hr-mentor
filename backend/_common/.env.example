POSTGRES_USER=postgres # or YOUR_POSTGRES_USER
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=ai-mentor
POSTGRES_HOST=localhost # or postgres  for docker

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY

# KEEP THIS LINES UNCHANGED
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini
# Pinecone
PINECONE_INDEX=ai-mentor-index
GROQ_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct