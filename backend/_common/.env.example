# Copy to backend/_common/.env — shared by all microservices (pydantic-settings env_file).
# Server
DATABASE_URL=postgresql://user:password@localhost:5432/ai-carrier-mentor
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# Pinecone
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX=ai-mentor-vacancies
PINECONE_INDEX_CVS_NAME=ai-mentor-cvs
# Namespace for CV vectors on the same index (must match rag-index upserts)
PINECONE_CV_NAMESPACE=cvs

GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct