# Server
PORT=8001

# Same optional Postgres check as cv-microservice
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_hr

# OpenAI — extraction (ChatOpenAI) + embeddings (OpenAIEmbeddings)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# text-embedding-3-small defaults to 1536 dimensions
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: set when index dimension differs (e.g. 1536)
OPENAI_EMBEDDING_DIMENSIONS=1536

# Groq — CV/vacancy ranking model
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=vacancies
# GET /v1/vacancies: max Pinecone hits per user (semantic query + user_id filter)
PINECONE_USER_VACANCIES_TOP_K=2000

