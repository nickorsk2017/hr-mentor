# Server
PORT=8001

# Same optional Postgres check as cv-microservice
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_hr

# OpenAI — extraction (ChatOpenAI) + embeddings (OpenAIEmbeddings)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# text-embedding-3-small defaults to 1536 dimensions
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: set when index dimension differs (e.g. 1536)
OPENAI_EMBEDDING_DIMENSIONS=1536

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=vacancies

# Llama via Ollama (LangChain ChatOllama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
